# ==========================================================================
# latexmk 設定: PDF はルート直下、中間ファイルは build/ に分ける
#   PDF はすぐ開けるように ./ に出す。
#   .aux .bbl .blg .fdb_latexmk .fls .log .out などは build/ に寄せる。
# ==========================================================================
$out_dir = '.';       # PDF などの最終成果物
$aux_dir = 'build';   # aux 系の中間ファイル
$emulate_aux = 1;     # TeX Live で out_dir と aux_dir を分けるために明示する
